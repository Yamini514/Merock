# Merock Realty frontend — environment configuration
# Copy to .env (or .env.local) and adjust as needed.

# Base URL of the backend API (no trailing slash).
# Local backend (puma default): http://localhost:9292/api
NEXT_PUBLIC_API_URL=http://localhost:9292/api

# Show the one-tap demo-account picker on the login page (seeded sample
# credentials from backend/scripts/seed.rb). Always on in `next dev`;
# set to true to also show it in a production build used for demos.
# REMOVE or set to false for a real production deployment.
NEXT_PUBLIC_SHOW_DEMO_LOGINS=true
